# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- Supabase (required for server.ts and Vercel serverless API) ---
# Project Settings → API: Project URL and service_role key (server only — never expose in Vite).
# Local dev: you can use .env.local (gitignored); server loads .env then .env.local.
# Use service_role here — the anon (public) key cannot insert into links/visits with RLS enabled.
#
# Vercel: Project → Settings → Environment Variables → add the same two vars for Production (and Preview).
# Do NOT prefix them with VITE_ (that would not apply to API routes; never expose service_role to the client).
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-secret"

# --- Vercel / split frontend + API (optional) ---
# Browser: API origin when the UI is hosted separately (e.g. https://your-api.railway.app).
# VITE_API_BASE_URL="https://your-api.example.com"
# Copied short links open here (defaults to current page origin). Usually your API/public host.
# VITE_LINK_BASE_URL="https://your-api.example.com"
# Express: allow the Vercel preview/production origin (required for cross-origin API + uploads).
# CORS_ORIGIN="https://your-app.vercel.app"
